# Volumes + binary data
/backups/
/storage/
/staging/
/n8n_data/
/vault_data/

# Secret patterns
*.env
*.env.*
.env*
*secret*
*credential*
*password*
*.pem
*.key
*_rsa
*_dsa
*_ed25519

# Vault encrypted bundles
*.gpg
/security/.vault-*

# Service configs with bootstrapped live secrets — never commit.
# Each file contains hex secret_key / encryption_key / jwt_secret values
# generated at deployment. Rebuild from templates instead.
/config/searxng/settings.yml

# Authelia secrets
/security/authelia/users_database.yml
/security/authelia-v2/users_database.yml
# Authelia config: filled by bootstrap with live JWT/session secrets — never commit.
# v1 is also root-owned 600 (unreadable by joly).
/security/authelia/configuration.yml
/security/authelia-v2/configuration.yml

# Restic
.restic-pw
.restic-repo

# Local-only state
/tmp/
/var/
*.pyc
__pycache__/
.DS_Store
*.swp

# Personal/business data — bank statements, invoice PDFs, attachment dumps.
# These contain account numbers + transaction detail and MUST NOT leave the
# host via the GitHub off-host-backup repo.
/data/natwest-inbox/
/data/invoice-pdfs/
/data/unknown-attachments/
/data/realm-scoped/
# Schema-only artifacts in /data are OK (e.g. realm-shadow-baseline.json
# tracked above — that's row counts, no row content).

# Build artefacts
node_modules/
/logs/

# Authelia runtime + backups (never commit secrets or session DB)
/security/authelia-v2/configuration.yml.bak.*
/security/authelia-v2/db.sqlite3
/security/authelia-v2/notification.txt
