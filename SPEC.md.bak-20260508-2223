DO $$ DECLARE t TEXT;
BEGIN
  FOREACH t IN ARRAY ARRAY['events','emails','invoices','bank_transactions',
    'epos_daily_reports','accommodation_daily_reports','till_reconciliation',
    'rent_payments','documents','cashflow_forecast']
