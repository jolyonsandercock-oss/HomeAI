{
  "type": "object",
  "title": "EmailClassifierOutcome",
  "description": "Output of the email-classifier AI worker. Matches the existing gmail-ingest-v1 'Classify Email (Ollama)' contract. Used by Ollama hot tier (qwen2.5:7b) and Haiku escalation.",
  "properties": {
    "category":         {
      "type": "string",
      "enum": ["invoice", "action-required", "report-attachment", "school-medical", "property", "pub", "fyi", "junk"]
    },
    "entity_id":        {
      "type": "integer",
      "enum": [1, 2, 3, 4],
      "description": "1=Trading (pub), 2=Estates (property), 3=Personal, 4=Family"
    },
    "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "summary":          { "type": "string", "minLength": 1, "maxLength": 100 },
    "requires_human":   { "type": "boolean" }
  },
  "required": ["category", "entity_id", "confidence_score", "summary", "requires_human"]
}
