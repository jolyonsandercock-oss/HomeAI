{
  "type": "object",
  "title": "ReportParserOutcome",
  "description": "Output of the report-parser AI worker. Used by Report Ingestion Pipeline P9 (Haiku) for periodic operational reports (e.g. utility statements, bank summaries, supplier scorecards).",
  "properties": {
    "status":         { "type": "string", "enum": ["success", "escalate", "fail"] },
    "confidence":     { "type": "number", "minimum": 0, "maximum": 1 },
    "reasoning":      { "type": "string", "minLength": 1, "maxLength": 500 },
    "worker":         { "type": "string", "const": "report_parser" },
    "tier_used":      { "type": "string", "enum": ["haiku", "sonnet"] },
    "requires_human": { "type": "boolean" },
    "report_type":    {
      "type": "string",
      "enum": ["utility_statement", "bank_summary", "vat_quarterly", "supplier_scorecard", "occupancy_report", "labour_report", "other"]
    },
    "period_start":   { "type": ["string", "null"], "format": "date" },
    "period_end":     { "type": ["string", "null"], "format": "date" },
    "vendor_or_source": { "type": ["string", "null"], "description": "Who issued the report (utility company, bank, etc)." },
    "key_metrics":    {
      "type": "object",
      "description": "Free-form key/value of headline figures, e.g. {\"total_consumption_kwh\": 1234, \"total_charge_gbp\": 456.78}.",
      "additionalProperties": { "type": ["string", "number", "boolean", "null"] }
    },
    "flags":          {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type":     { "type": "string" },
          "severity": { "type": "string", "enum": ["info", "warn", "high"] },
          "message":  { "type": "string" }
        },
        "required": ["type", "severity", "message"]
      },
      "description": "Anomalies or items needing attention."
    },
    "summary":        { "type": "string", "minLength": 1, "maxLength": 1000 }
  },
  "required": ["status", "confidence", "reasoning", "worker", "tier_used", "requires_human", "report_type", "summary"]
}
