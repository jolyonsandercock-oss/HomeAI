# Caddyfile staged for U57 — adds FQDN + TLS + Authelia forward_auth.
#
# Strategy: keep all existing IP-based routes (http://:80) UNCHANGED so they
# remain a tested fallback. Add a new https://jolybox.tailc27dff.ts.net
# listener that has forward_auth on /dashboard* — after smoke tests prove
# the FQDN path works, a follow-up cleanup can remove the IP backdoor.

{
    auto_https off
}

# Direct port-passthrough proxies (existing services on their familiar ports)
http://100.104.82.53:5678 {
    reverse_proxy homeai-n8n:5678
}

http://100.104.82.53:3000 {
    reverse_proxy homeai-metabase:3000
}

http://100.104.82.53:8080 {
    reverse_proxy homeai-open-webui:8080
}

# IP-based path-routed listener — UNCHANGED, kept as rollback path.
http://:80 {
    # SEC 2026-07-03 (F1 item 5): strip client-supplied Authelia identity
    # headers. This listener has NO forward_auth, and build-dashboard runs
    # REALM_ENFORCE=1 reading Remote-Groups — a forged `Remote-Groups: all`
    # on /api/pub/* elevated to owner realm. Site-level request_header runs
    # before the handle subroutes (Caddyfile directive order), so nothing
    # client-supplied survives to any upstream.
    request_header -Remote-User
    request_header -Remote-Groups
    request_header -Remote-Name
    request_header -Remote-Email
    # SEC 2026-06-16: /dashboard is owner-internal and must not be served
    # unauthenticated even on the Tailscale-only :80 listener. Bounce browsers
    # to the Authelia-gated HTTPS FQDN instead of proxying straight through.
    handle /dashboard {
        redir https://jolybox.tailc27dff.ts.net/dashboard/ permanent
    }
    handle /dashboard/* {
        redir https://jolybox.tailc27dff.ts.net{uri} permanent
    }
    handle /pub {
        rewrite * /pub
        reverse_proxy homeai-build-dashboard:8090
    }
    handle /pub/* {
        reverse_proxy homeai-build-dashboard:8090
    }
    # SEC 2026-06-16: forensics exposes dead-letter payloads, error messages and
    # trace IDs — internal-only. UI redirects to the gated HTTPS FQDN; the API is
    # hard-403'd here (no redirect, so programmatic callers fail loudly instead of
    # leaking on plain HTTP).
    handle /forensics {
        redir https://jolybox.tailc27dff.ts.net/forensics permanent
    }
    handle /forensics/* {
        redir https://jolybox.tailc27dff.ts.net{uri} permanent
    }
    handle /api/forensics/* {
        respond "forbidden on this listener — use https://jolybox.tailc27dff.ts.net" 403
    }
    handle /api/pub/* {
        reverse_proxy homeai-build-dashboard:8090
    }
    handle /playground {
        rewrite * /playground
        reverse_proxy homeai-build-dashboard:8090
    }
    handle /api/playground/* {
        reverse_proxy homeai-build-dashboard:8090
    }
    handle_path /markitdown/* {
        reverse_proxy homeai-markitdown:8004
    }
    handle /markitdown {
        redir /markitdown/ permanent
    }
    # Don't strip the prefix — Authelia is configured at server.address=…:9091/auth
    # so it knows about /auth/ and generates SPA paths that include it.
    handle /auth/* {
        reverse_proxy homeai-authelia:9091
    }
    handle /auth {
        redir /auth/ permanent
    }
    handle_path /search/* {
        reverse_proxy homeai-searxng:8080
    }
    handle /search {
        redir /search/ permanent
    }
    handle /healthz {
        respond "ok" 200
    }
    handle / {
        rewrite * /landing
        reverse_proxy homeai-build-dashboard:8090
    }
}

# FQDN + TLS listener — U57 R3+R4.
# /auth/* + /healthz are open. Everything else is forward_auth-gated and
# proxied to build-dashboard directly — no URL prefix games, so the
# dashboard's root-relative fetch calls (/api/snapshot, /api/healthz-deep,
# /api/m/mobile, /api/economics/overview, ...) hit the right endpoint.
https://jolybox.tailc27dff.ts.net {
    tls /etc/caddy/tls/jolybox.tailc27dff.ts.net.crt /etc/caddy/tls/jolybox.tailc27dff.ts.net.key

    # F1 item 5 (2026-07-03): JSON access log — usage data feeds the F2
    # two-stack consolidation decision. /data is the caddy_data volume.
    log {
        output file /data/access-fqdn.log {
            roll_size 10MiB
            roll_keep 5
        }
        format json
    }

    # SEC 2026-07-03 (F1 item 5): strip client-supplied Authelia identity
    # headers BEFORE forward_auth re-injects the real values via copy_headers.
    # forward_auth only overwrites headers present in Authelia's verify
    # response — anything it doesn't set would otherwise pass through
    # client-controlled (lib/realm.ts spoofing follow-up). Site-level
    # request_header runs before the handle subroutes in directive order.
    request_header -Remote-User
    request_header -Remote-Groups
    request_header -Remote-Name
    request_header -Remote-Email

    # Authelia portal — open (must be reachable to log in).
    handle /auth/* {
        reverse_proxy homeai-authelia:9091
    }
    handle /auth {
        redir /auth/ permanent
    }

    # Open Caddy-level liveness — for the watchdog.
    handle /healthz {
        respond "ok" 200
    }

    # Data-proxy for Vercel + other external HTTPS callers — bearer-token
    # auth at the application layer (HOMEAI_DATA_TOKEN), no Authelia cookie.
    handle_path /data/* {
        reverse_proxy homeai-data-proxy:8771
    }

    # homeai-frontend (Next.js, U123/U127) — built with basePath='/app' so
    # every emitted asset/route/Link self-prefixes. Caddy does NOT strip the
    # prefix; Next.js sees the full /app/ path and routes correctly.
    # Forward_auth gated (Authelia owner-realm session).
    @app path /app /app/*
    handle @app {
        forward_auth homeai-authelia:9091 {
            uri /api/verify?rd=https://jolybox.tailc27dff.ts.net/auth/
            copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
        }
        reverse_proxy homeai-frontend:3000
    }

    # Grafana (U143 — Phase 5 Health dashboards + n8n/postgres metrics).
    # Authelia-gated. Grafana is configured with GF_SERVE_FROM_SUB_PATH=true
    # and GF_SERVER_ROOT_URL=https://.../grafana/ so it expects the /grafana
    # prefix in incoming requests. Use `handle` (NOT `handle_path`) so the
    # prefix is preserved both for the forward_auth's rd= build and for
    # grafana's own router.
    @grafana path /grafana /grafana/*
    handle @grafana {
        forward_auth homeai-authelia:9091 {
            uri /api/verify?rd=https://jolybox.tailc27dff.ts.net/auth/
            copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
        }
        reverse_proxy homeai-grafana:3000
    }

    # U-cutover 2026-06-25: the new Next.js dashboard (/app) is now primary. The bare
    # domain and the old /dashboard bookmark redirect to it. The 6 kept legacy features
    # (/documents /memory /playground /search /vehicles /counterparty-review) are their
    # own paths and fall through to the catch-all below — unaffected.
    @landing path / /dashboard /dashboard/
    handle @landing {
        redir /app/ permanent
    }

    # Everything else: forward_auth, then proxy to the dashboard.
    # Remote-Groups carries the realm membership which the dashboard
    # middleware (REALM_ENFORCE=1) reads and maps to app.current_realm.
    handle {
        forward_auth homeai-authelia:9091 {
            uri /api/verify?rd=https://jolybox.tailc27dff.ts.net/auth/
            copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
        }
        reverse_proxy homeai-build-dashboard:8090
    }
}
