{
  "uid": "home-ai-pipelines",
  "title": "Home AI — Pipeline Health",
  "tags": ["home-ai", "phase-1", "pipelines"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "events_overflow (must be 0)",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "events_overflow_count" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Dead letter total",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "dead_letter_count" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 1000 }] } } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Dead letters / last hour",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "dead_letter_recent_count" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 50 }] } } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Pending events",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(events_pending_count)" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 500 }] } } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Oldest stuck lease",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "events_processing_lease_age_oldest_seconds" }],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 600 }, { "color": "red", "value": 1800 }] } } }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Email review queue",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "emails_review_queue_count" }]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Dead letter growth (rate/min)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(dead_letter_count[5m]) * 60", "legendFormat": "rows/min" }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 25 } } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Events by status",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "events_status_count", "legendFormat": "{{status}}" }],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "stacking": { "mode": "normal" }, "fillOpacity": 25 } } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "audit_log activity by pipeline (last hour count)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "audit_log_recent_count", "legendFormat": "{{pipeline}}/{{result}}" }],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60 } } }
    },
    {
      "id": 10,
      "type": "table",
      "title": "Events partition row counts",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "events_partition_rows_reltuples", "format": "table", "instant": true }],
      "fieldConfig": { "defaults": { "custom": { "align": "left" } } },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true, "server": true } } },
        { "id": "sortBy", "options": { "sort": [{ "field": "partition", "desc": false }] } }
      ]
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Bank txns awaiting reconciliation",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "bank_unreconciled_count" }]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Pending events by type",
      "gridPos": { "h": 4, "w": 18, "x": 6, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "events_pending_count", "legendFormat": "{{event_type}}" }],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Stale lease activity (last hour)",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "stale_lease_recovery_recent_recovered_recent", "legendFormat": "recovered" },
        { "expr": "stale_lease_recovery_recent_dead_lettered_recent", "legendFormat": "dead-lettered" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } } } }
    }
  ]
}
