{
  "uid": "home-ai-slo",
  "title": "Home AI — SLO / SLA",
  "tags": ["home-ai", "slo"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-7d", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Pipeline success rate (24h)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "100 * sum(audit_log_recent_count{result=\"success\"}) / clamp_min(sum(audit_log_recent_count), 1)",
        "legendFormat": "%"
      }],
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "red", "value": null }, { "color": "yellow", "value": 90 }, { "color": "green", "value": 99 }
        ] } } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Events overflow",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "events_overflow_count" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "red", "value": 1 }
        ] } } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Dead letter (24h, real)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "dead_letter_count" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 50 }
        ] } } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active alerts (firing)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(ALERTS{alertstate=\"firing\"}) or vector(0)" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "red", "value": 1 }
        ] } } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Audit success vs failure (last hour count, 7d)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (result) (audit_log_recent_count)", "legendFormat": "{{result}}" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 25 } } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Pipeline activity by name",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (pipeline) (audit_log_recent_count)", "legendFormat": "{{pipeline}}" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Stale lease activity",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "stale_lease_recovery_recent_recovered_recent",     "legendFormat": "recovered" },
        { "expr": "stale_lease_recovery_recent_dead_lettered_recent", "legendFormat": "dead-lettered" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } } } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "HMAC verifier (24h coverage)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "hmac_verification_recent_verified_24h", "legendFormat": "verified" },
        { "expr": "hmac_verification_recent_failed_24h",   "legendFormat": "failed" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 25 } } }
    },
    {
      "id": 9,
      "type": "table",
      "title": "Pending events by type",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "events_pending_count", "format": "table", "instant": true }],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true, "server": true } } },
        { "id": "sortBy", "options": { "sort": [{ "field": "Value", "desc": true }] } }
      ]
    },
    {
      "id": 10,
      "type": "table",
      "title": "Events by status",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "events_status_count", "format": "table", "instant": true }],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true, "server": true } } },
        { "id": "sortBy", "options": { "sort": [{ "field": "Value", "desc": true }] } }
      ]
    }
  ]
}
